VITE_API_URL="https://your-cloud-run-backend-url.run.app"
PYTHON_API_URL="http://127.0.0.1:8000"
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN="advisoai-497313.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="advisoai-497313"
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_RAZORPAY_KEY_ID=""
# VITE_GOOGLE_ANALYTICS_ID: Optional GA4 measurement ID, for example G-XXXXXXXXXX.
VITE_GOOGLE_ANALYTICS_ID=""

# Optional for the legacy Express wrapper only.
APP_URL="http://localhost:3000"

# Backend-only values. These are read by FastAPI and must not be exposed as VITE_ vars.
OPENAI_API_KEY=""
AI_MODEL="gpt-4o-mini"
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RESEND_API_KEY=""
EMAIL_FROM_WELCOME="Adviso AI <welcome@adviso.ai>"
EMAIL_FROM_SUPPORT="Adviso AI Support <support@adviso.ai>"
EMAIL_REPLY_TO="support@adviso.ai"
APP_PUBLIC_URL="https://adviso.ai"
EMAIL_LOGO_URL="https://adviso.ai/favicon.png"
EMAIL_VALIDATION_REQUIRE_MX=true
EMAIL_VALIDATION_ALLOWED_PUBLIC_DOMAINS="gmail.com,googlemail.com,outlook.com,hotmail.com,live.com,msn.com,yahoo.com,ymail.com,icloud.com,me.com,mac.com,proton.me,protonmail.com,zoho.com,hey.com,aol.com"
EMAIL_VALIDATION_BLOCKED_DOMAINS=""
# For local development with Supabase, prefer the IPv4-compatible pooler URL.
# Direct db.<project>.supabase.co URLs may be IPv6-only on some networks.
DATABASE_URL="postgresql://USER:PASSWORD@POOLER_HOST:6543/postgres?sslmode=require"
AUTO_CREATE_TABLES=true
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10
DB_POOL_TIMEOUT_SECONDS=10
REDIS_URL="rediss://default:YOUR_UPSTASH_PASSWORD@YOUR_UPSTASH_HOST.upstash.io:6379"
AI_CACHE_TTL_SECONDS=900
CELERY_RESULT_EXPIRES_SECONDS=86400
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_WORKER_CONCURRENCY=2
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=900
CELERY_TASK_TIME_LIMIT_SECONDS=1200
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="datasets"
MAX_UPLOAD_SIZE_BYTES=209715200
FIREBASE_PROJECT_ID="advisoai-497313"
# Local dev can use `gcloud auth application-default login`.
# Leave these empty unless you explicitly use backend service-account credentials.
FIREBASE_CREDENTIALS_JSON=""
FIREBASE_CREDENTIALS_PATH=""
RATE_LIMIT_PER_MINUTE=120
UPLOAD_RATE_LIMIT_PER_MINUTE=10
AI_RATE_LIMIT_PER_MINUTE=30
WEBSOCKET_RATE_LIMIT_PER_MINUTE=60
ABANDONED_JOB_MINUTES=45
EXPIRED_CACHE_CLEANUP_LIMIT=500
