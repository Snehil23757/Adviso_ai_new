VITE_API_URL="https://your-cloud-run-backend-url.run.app"
PYTHON_API_URL="http://127.0.0.1:8000"
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN="advisoai-497313.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="advisoai-497313"
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_RAZORPAY_KEY_ID=""
# VITE_GOOGLE_ANALYTICS_ID: Optional GA4 measurement ID, for example G-XXXXXXXXXX.
VITE_GOOGLE_ANALYTICS_ID=""

# Optional for the legacy Express wrapper only.
APP_URL="http://localhost:3000"

# Backend-only values. These are read by FastAPI and must not be exposed as VITE_ vars.
OPENAI_API_KEY=""
AI_MODEL="gpt-4o-mini"
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
# For local development with Supabase, prefer the IPv4-compatible pooler URL.
# Direct db.<project>.supabase.co URLs may be IPv6-only on some networks.
DATABASE_URL="postgresql://USER:PASSWORD@POOLER_HOST:6543/postgres?sslmode=require"
AUTO_CREATE_TABLES=true
REDIS_URL="rediss://default:YOUR_UPSTASH_PASSWORD@YOUR_UPSTASH_HOST.upstash.io:6379"
AI_CACHE_TTL_SECONDS=900
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="datasets"
MAX_UPLOAD_SIZE_BYTES=209715200
FIREBASE_PROJECT_ID="advisoai-497313"
# Local dev can use `gcloud auth application-default login`.
# Leave these empty unless you explicitly use backend service-account credentials.
FIREBASE_CREDENTIALS_JSON=""
FIREBASE_CREDENTIALS_PATH=""
