OPENAI_API_KEY=""
AI_MODEL="gpt-4o-mini"
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
# For local development with Supabase, prefer the IPv4-compatible pooler URL.
# Direct db.<project>.supabase.co URLs may be IPv6-only on some networks.
DATABASE_URL="postgresql://USER:PASSWORD@POOLER_HOST:6543/postgres?sslmode=require"
AUTO_CREATE_TABLES=true
REDIS_URL="rediss://default:YOUR_UPSTASH_PASSWORD@YOUR_UPSTASH_HOST.upstash.io:6379"
AI_CACHE_TTL_SECONDS=900
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="datasets"
MAX_UPLOAD_SIZE_BYTES=209715200
FIREBASE_PROJECT_ID="advisoai-497313"
# Local dev can use `gcloud auth application-default login`.
# Leave these empty unless you explicitly use backend service-account credentials.
FIREBASE_CREDENTIALS_JSON=""
FIREBASE_CREDENTIALS_PATH=""
BACKEND_HOST="127.0.0.1"
BACKEND_PORT=8000
RATE_LIMIT_PER_MINUTE=120
ALLOWED_ORIGINS="https://advisoai.in,https://www.advisoai.in,https://advisoai-497313.web.app"
ALLOWED_ORIGIN_REGEX=""
